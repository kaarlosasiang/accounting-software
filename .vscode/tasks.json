    {
      "label": "Lint: All",
      "type": "shell",
      "command": "pnpm lint",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"]
    }
  ]
}
